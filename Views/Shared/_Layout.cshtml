@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web Bán Sách</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <header class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">📚 Web Bán Sách</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <!-- Menu trái -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">🏠 Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Sach" asp-action="Index">📖 Sách</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Cart" asp-action="Index">🛒 Giỏ hàng</a>
                    </li>
                    @if (HttpContextAccessor.HttpContext.Session.GetInt32("MaKH") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cart" asp-action="MyOrders">🧾 Đơn hàng của tôi</a>
                        </li>
                    }
                </ul>

                <!-- Menu phải -->
                <ul class="navbar-nav ms-auto">
                    @if (HttpContextAccessor.HttpContext.Session.GetInt32("MaKH") != null)
                    {
                        <li class="nav-item me-3">
                            <span class="navbar-text text-white">
                                👋 Xin chào, <strong>@HttpContextAccessor.HttpContext.Session.GetString("TenKH")</strong>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light me-2" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-warning" asp-controller="Account" asp-action="Signup">Đăng ký</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </header>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <footer class="bg-light text-center p-3 mt-4 border-top">
        <p class="mb-0">&copy; 2025 - Web Bán Sách | <a href="#">Liên hệ</a></p>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>

@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web Bán Sách</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        /* Navbar */
        .navbar {
            background: linear-gradient(90deg, #0d6efd, #0b5ed7);
        }

            .navbar .nav-link {
                color: #fff !important;
                transition: 0.3s;
            }

                .navbar .nav-link:hover {
                    color: #ffc107 !important;
                }

        .navbar-brand img {
            height: 40px;
            margin-right: 8px;
        }
        /* Footer */
        footer {
            background: #0d6efd;
        }

            footer a:hover {
                text-decoration: underline;
            }
    </style>
</head>
<body class="bg-light">
    <!-- Navbar -->
    <header class="navbar navbar-expand-lg navbar-dark shadow-sm sticky-top">
        <div class="container">
            <!-- Logo -->
            <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <img src="~/images/logoD.jpg" alt="Logo" /> Web Bán Sách
            </a>

            <!-- Nút toggle mobile -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Menu -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <!-- Menu trái -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door"></i> Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Sach" asp-action="Index">
                            <i class="bi bi-journal-bookmark"></i> Sách
                        </a>
                    </li>
                    <li class="nav-item position-relative">
                        <a class="nav-link" asp-controller="Cart" asp-action="Index">
                            <i class="bi bi-cart3"></i> Giỏ hàng
                            <span class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill">
                                @(HttpContextAccessor.HttpContext.Session.GetInt32("CartCount") ?? 0)
                            </span>
                        </a>
                    </li>
                    @if (HttpContextAccessor.HttpContext.Session.GetInt32("MaKH") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cart" asp-action="MyOrders">
                                <i class="bi bi-receipt"></i> Đơn hàng
                            </a>
                        </li>
                    }
                </ul>

                <!-- Menu phải -->
                <ul class="navbar-nav ms-auto align-items-center">
                    @if (HttpContextAccessor.HttpContext.Session.GetInt32("MaKH") != null)
                    {
                        <!-- Dropdown tài khoản -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" id="accountDropdown" role="button" data-bs-toggle="dropdown">
                                👋 Xin chào, <strong>@HttpContextAccessor.HttpContext.Session.GetString("TenKH")</strong>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Settings">
                                        <i class="bi bi-gear"></i> Cài đặt
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light me-2" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-warning" asp-controller="Account" asp-action="Signup">
                                <i class="bi bi-person-plus"></i> Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </header>

    <!-- Nội dung chính -->
    <main class="container mt-4">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="text-light text-center p-4 mt-5 border-top shadow-sm">
        <p class="mb-2">
            &copy; 2025 - <strong>Web Bán Sách</strong> |
            <a class="text-warning text-decoration-none" asp-controller="Contact" asp-action="Index">Liên hệ</a>
        </p>
        <div>
            <a href="#" class="text-light me-3"><i class="bi bi-facebook"></i></a>
            <a href="#" class="text-light me-3"><i class="bi bi-instagram"></i></a>
            <a href="#" class="text-light"><i class="bi bi-twitter"></i></a>
        </div>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>

@model IEnumerable<QLBanSachWeb.Models.Sach>

<h1>Danh sách sách</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Tên sách</th>
            <th>Tác giả</th>
            <th>Loại sách</th>
            <th>NXB</th>
            <th>Năm XB</th>
            <th>Giá bán</th>
            <th>Số Lượng</th>
            <th>Mô Tả</th>
            <th>Hình ảnh</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TenSach</td>
                <td>@item.TacGia</td>
                <td>@item.MaLoaiNavigation?.TenLoai</td>
                <td>@item.NXB</td>
                <td>@item.NamXB</td>
                <td>@item.GiaBan.ToString("C")</td>
                <td>@item.SoLuong</td>
                <td>@item.MoTa</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                    {
                        <img src="~/images/@item.HinhAnh" width="80" />
                    }
                </td>
                <td>
                    @* Thông báo lỗi nếu có *@
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">
                            @TempData["ErrorMessage"]
                        </div>
                    }

                    <a asp-action="Edit" asp-route-id="@item.MaSach" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.MaSach" class="btn btn-sm btn-info">Details</a>
                    <form asp-action="Delete" asp-route-id="@item.MaSach" method="post" style="display:inline">
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Bạn có chắc chắn muốn xóa sách này?');">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

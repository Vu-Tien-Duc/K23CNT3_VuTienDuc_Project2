@model QLBanSachWeb.Models.DonHang

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="alert alert-success mt-4">
    <h3>✅ Đặt hàng thành công!</h3>
    <p>Mã đơn hàng: <strong>#@Model.MaDH</strong></p>
    <p>Ngày đặt: @(Model.NgayDat?.ToString("dd/MM/yyyy HH:mm"))</p>
    <p>Tổng tiền: <strong>@Model.TongTien?.ToString("N0") đ</strong></p>
    <p>
        Trạng thái:
        @if (Model.TrangThai == "Chờ xác nhận")
        {
            <span class="badge bg-warning text-dark">@Model.TrangThai</span>
        }
        else if (Model.TrangThai == "Đang giao")
        {
            <span class="badge bg-info text-dark">@Model.TrangThai</span>
        }
        else if (Model.TrangThai == "Hoàn tất")
        {
            <span class="badge bg-success">@Model.TrangThai</span>
        }
        else
        {
            <span class="badge bg-secondary">@Model.TrangThai</span>
        }
    </p>
</div>

<h4 class="mt-4">👤 Thông tin khách hàng</h4>
<ul class="list-group mb-4">
    <li class="list-group-item"><strong>Họ tên:</strong> @Model.MaKHNavigation?.HoTen</li>
    <li class="list-group-item"><strong>Email:</strong> @Model.MaKHNavigation?.Email</li>
    <li class="list-group-item"><strong>Địa chỉ:</strong> @Model.MaKHNavigation?.DiaChi</li>
    <li class="list-group-item"><strong>Số điện thoại:</strong> @Model.MaKHNavigation?.SDT</li>
</ul>

<h4>📚 Chi tiết đơn hàng</h4>
<table class="table table-bordered table-striped">
    <thead class="table-light">
        <tr>
            <th>Sách</th>
            <th>Giá</th>
            <th>Số lượng</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ct in Model.CT_DonHangs)
        {
            <tr>
                <td>@ct.MaSachNavigation?.TenSach</td>
                <td>@ct.DonGia.ToString("N0") đ</td>
                <td>@ct.SoLuong</td>
                <td>@((ct.SoLuong * ct.DonGia).ToString("N0")) đ</td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3 d-flex gap-2">
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
        🏠 Tiếp tục mua sắm
    </a>
    <a asp-controller="Cart" asp-action="MyOrders" class="btn btn-success">
        📋 Xem đơn hàng của tôi
    </a>
</div>

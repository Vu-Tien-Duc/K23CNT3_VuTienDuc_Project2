    @model IEnumerable<QLBanSachWeb.Models.CT_GioHang>

    @{
        ViewData["Title"] = "Giỏ hàng";
    }

    <h2 class="mb-4">🛒 Giỏ hàng của bạn</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Giỏ hàng trống!</div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Sách</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaSachNavigation.TenSach</td>
                        <td>@item.MaSachNavigation.GiaBan.ToString("N0") đ</td>
                        <td>
                            <form asp-action="Update" asp-controller="Cart" method="post" class="d-flex">
                                <input type="hidden" name="maSach" value="@item.MaSach" />
                                <input type="number" name="soLuong" value="@item.SoLuong" min="1" class="form-control me-2" style="width:80px;" />
                                <button type="submit" class="btn btn-sm btn-primary">Cập nhật</button>
                            </form>
                        </td>
                    <td>@((item.SoLuong * item.MaSachNavigation.GiaBan).ToString("N0")) đ</td>

                        <td>
                            <a asp-action="Remove" asp-route-maSach="@item.MaSach" class="btn btn-sm btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    <div class="d-flex justify-content-between align-items-center mt-3">
        <h4 class="text-success">Tổng tiền: @ViewBag.Total.ToString("N0") đ</h4>
        <div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg me-2">
                ← Tiếp tục mua sắm
            </a>
            <a asp-action="Checkout" class="btn btn-success btn-lg">Thanh toán</a>
        </div>
    </div>

    }

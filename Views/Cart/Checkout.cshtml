@model IEnumerable<QLBanSachWeb.Models.CT_GioHang>

@{
    ViewData["Title"] = "Xác nhận thanh toán";
}

<h3>🛒 Xác nhận đơn hàng</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Sách</th>
            <th>Giá</th>
            <th>Số lượng</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaSachNavigation.TenSach</td>
                <td>@item.MaSachNavigation.GiaBan.ToString("N0") đ</td>
                <td>
                    <form asp-action="Update" method="post" class="d-flex gap-2">
                        <input type="hidden" name="maSach" value="@item.MaSach" />
                        <input type="number" name="soLuong" value="@item.SoLuong" min="1" class="form-control w-25" />
                        <button type="submit" class="btn btn-sm btn-primary">Cập nhật</button>
                    </form>
                </td>
                <td>@((item.SoLuong * item.MaSachNavigation.GiaBan).ToString("N0")) đ</td>
            </tr>
        }
    </tbody>
</table>

<form asp-action="CheckoutConfirm" method="post">
    <button type="submit" class="btn btn-success">✅ Xác nhận đặt hàng</button>
    <a asp-controller="Cart" asp-action="Index" class="btn btn-secondary">Quay lại giỏ hàng</a>
</form>

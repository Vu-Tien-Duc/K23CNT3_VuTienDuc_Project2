@model IEnumerable<QLBanSachWeb.Models.CT_GioHang>

@{
    ViewData["Title"] = "Xác nhận thanh toán";
}

<h3>🛒 Xác nhận đơn hàng</h3>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Sách</th>
            <th>Giá</th>
            <th>Số lượng</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaSachNavigation.TenSach</td>
                <td>@item.MaSachNavigation.GiaBan.ToString("N0") đ</td>
                <td>@item.SoLuong</td>
                <td>@((item.SoLuong * item.MaSachNavigation.GiaBan).ToString("N0")) đ</td>
            </tr>
        }
    </tbody>
</table>

<form asp-action="CheckoutConfirm" method="post">
    <button type="submit" class="btn btn-success">✅ Xác nhận đặt hàng</button>
    <a asp-controller="Cart" asp-action="Index" class="btn btn-secondary">Quay lại giỏ hàng</a>
</form>

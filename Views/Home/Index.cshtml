@using QLBanSachWeb.Models
@{
    ViewData["Title"] = "Trang chủ";
    var bestSellers = ViewBag.BestSellers as List<Sach>;
    var featuredBooks = ViewBag.FeaturedBooks as List<Sach>;
}

<!-- Banner Slider -->
<div id="bannerCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
    <div class="carousel-inner rounded-3 shadow-sm" style="height: 280px;">

        <!-- Banner 1 -->
        <div class="carousel-item active">
            <a href="https://www.fahasa.com/sach-moi.html" target="_blank">
                <img src="https://cdn0.fahasa.com/media/wysiwyg/Thang-09-2024/TrangTruyenTranh_T923_Banner_840x320.jpg"
                     class="d-block w-100 h-100" style="object-fit: cover;" alt="Fahasa Banner">
                <div class="carousel-caption d-none d-md-block">
                    <h5 class="fw-bold">📚 Sách Mới Nhất</h5>
                    <p>Cập nhật kho sách mới mỗi ngày</p>
                </div>
            </a>
        </div>

        <!-- Banner 2 -->
        <div class="carousel-item">
            <a href="https://tiki.vn/nha-sach-tiki/c8322" target="_blank">
                <img src="https://salt.tikicdn.com/cache/w1080/ts/banner/7b/8b/72/34a1f61a8fa665c2f7c1210005f466d8.jpg"
                     class="d-block w-100 h-100" style="object-fit: cover;" alt="Tiki Banner">
                <div class="carousel-caption d-none d-md-block">
                    <h5 class="fw-bold">🔥 Giảm giá cực sốc</h5>
                    <p>Ưu đãi tới 50% tại Tiki</p>
                </div>
            </a>
        </div>

        <!-- Banner 3 -->
        <div class="carousel-item">
            <a href="https://www.vinabook.com/" target="_blank">
                <img src="https://cdn0.fahasa.com/media/wysiwyg/Thang-08-2024/TrangVanHoc_T823_Banner_840x320.jpg"
                     class="d-block w-100 h-100" style="object-fit: cover;" alt="Vinabook Banner">
                <div class="carousel-caption d-none d-md-block">
                    <h5 class="fw-bold">🚚 Miễn phí vận chuyển</h5>
                    <p>Đơn hàng từ 250K trở lên</p>
                </div>
            </a>
        </div>
    </div>

    <!-- Nút điều hướng -->
    <button class="carousel-control-prev" type="button" data-bs-target="#bannerCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Trước</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#bannerCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Sau</span>
    </button>
</div>

<div class="container my-4">

    <!-- Sách Nổi Bật -->
    <h3 class="mb-4 fw-bold text-primary text-center">🌟 Sách Nổi Bật</h3>
    @if (featuredBooks != null && featuredBooks.Any())
    {
        <div class="row row-cols-2 row-cols-md-4 g-4">
            @foreach (var item in featuredBooks)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-4 book-card">
                        <div class="position-relative">
                            <img src="~/images/@(string.IsNullOrEmpty(item.HinhAnh) ? "no-image.png" : item.HinhAnh)"
                                 class="card-img-top rounded-top" alt="@item.TenSach"
                                 style="height:220px; object-fit:cover;" />
                            <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2">⭐ Hot</span>
                        </div>
                        <div class="card-body text-center d-flex flex-column">
                            <h6 class="fw-bold text-truncate text-primary">@item.TenSach</h6>
                            <small class="text-muted">✍ @item.TacGia</small>
                            <p class="fw-bold text-danger mt-2">@item.GiaBan.ToString("n0") ₫</p>
                            <div class="mt-auto">
                                <a asp-action="Details" asp-route-id="@item.MaSach"
                                   class="btn btn-outline-primary btn-sm me-2">
                                    <i class="bi bi-info-circle"></i> Chi tiết
                                </a>
                                <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.MaSach"
                                   class="btn btn-success btn-sm @(item.SoLuong == 0 ? "disabled" : "")">
                                    <i class="bi bi-cart-plus"></i> Giỏ
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted text-center">Không có sách nổi bật.</p>
    }

    <!-- Sách Bán Chạy -->
    <h3 class="mt-5 mb-4 fw-bold text-success text-center">🔥 Sách Bán Chạy</h3>
    @if (bestSellers != null && bestSellers.Any())
    {
        <div class="row row-cols-2 row-cols-md-4 g-4">
            @foreach (var item in bestSellers)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-4 book-card">
                        <div class="position-relative">
                            <img src="~/images/@(string.IsNullOrEmpty(item.HinhAnh) ? "no-image.png" : item.HinhAnh)"
                                 class="card-img-top rounded-top" alt="@item.TenSach"
                                 style="height:220px; object-fit:cover;" />
                            <span class="badge bg-danger position-absolute top-0 start-0 m-2">🔥 Best Seller</span>
                        </div>
                        <div class="card-body text-center d-flex flex-column">
                            <h6 class="fw-bold text-truncate text-success">@item.TenSach</h6>
                            <small class="text-muted">✍ @item.TacGia</small>
                            <p class="fw-bold text-danger mt-2">@item.GiaBan.ToString("n0") ₫</p>
                            <div class="mt-auto">
                                <a asp-action="Details" asp-route-id="@item.MaSach"
                                   class="btn btn-outline-success btn-sm me-2">
                                    <i class="bi bi-eye"></i> Xem
                                </a>
                                <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.MaSach"
                                   class="btn btn-warning btn-sm text-white @(item.SoLuong == 0 ? "disabled" : "")">
                                    <i class="bi bi-cart-fill"></i> Mua
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted text-center">Không có sách bán chạy.</p>
    }
</div>

<!-- CSS Hover card đẹp hơn -->
<style>
    .book-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .book-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }
</style>

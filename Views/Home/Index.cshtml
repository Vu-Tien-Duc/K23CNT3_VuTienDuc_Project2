@model IEnumerable<QLBanSachWeb.Models.Sach>

@{
    ViewData["Title"] = "Danh sách sách";
    var categories = ViewBag.Categories as List<QLBanSachWeb.Models.LoaiSach>;
    int? selectedCategory = ViewBag.SelectedCategory as int?;
}

<h2>Danh sách sách</h2>

<form asp-action="Index" method="get" class="mb-3">
    <input type="text" name="searchString" placeholder="Tìm kiếm sách..." class="form-control mb-2" />

    <select name="categoryId" class="form-select mb-2">
        <option value="">-- Tất cả thể loại --</option>
        @if (categories != null)
        {
            foreach (var cat in categories)
            {
                <option value="@cat.MaLoai" selected="@(selectedCategory == cat.MaLoai)">
                    @cat.TenLoai
                </option>
            }
        }
    </select>

    <button type="submit" class="btn btn-primary">Lọc</button>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Tên sách</th>
            <th>Tác giả</th>
            <th>Giá</th>
            <th>Hình ảnh</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.TenSach</td>
                <td>@item.TacGia</td>
                <td>@item.GiaBan.ToString("n0") ₫</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                    {
                        <img src="~/images/@item.HinhAnh" width="80" />
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.MaSach" class="btn btn-info btn-sm">Chi tiết</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@model IEnumerable<QLBanSachWeb.Models.Sach>

@{
    ViewData["Title"] = "Trang chủ";
}

<h2>Danh sách Sách</h2>

<form method="get" asp-action="Index" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" placeholder="Tìm kiếm sách..." class="form-control" />
        <button type="submit" class="btn btn-primary">Tìm</button>
    </div>
</form>

<div class="row mt-3">
    @foreach (var item in Model)
    {
        <div class="col-md-3 mb-4 d-flex">
            <div class="card h-100 shadow-sm w-100">
                @if (!string.IsNullOrEmpty(item.HinhAnh))
                {
                    <img src="~/images/@item.HinhAnh" class="card-img-top img-fluid"
                         style="height: 200px; object-fit: cover;" alt="@item.TenSach" />
                }
                else
                {
                    <img src="~/images/no-image.png" class="card-img-top img-fluid"
                         style="height: 200px; object-fit: cover;" alt="No image" />
                }
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-truncate">@item.TenSach</h5>
                    <p class="card-text text-muted">Tác giả: @item.TacGia</p>
                    <p class="text-danger fw-bold">@item.GiaBan.ToString("N0") đ</p>
                    <a asp-action="Details" asp-route-id="@item.MaSach" class="btn btn-info mt-auto">Chi tiết</a>
                </div>
            </div>
        </div>
    }
</div>

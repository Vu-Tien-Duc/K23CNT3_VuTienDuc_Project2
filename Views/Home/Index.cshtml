@model IEnumerable<QLBanSachWeb.Models.Sach>

@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as List<QLBanSachWeb.Models.LoaiSach>;
    int? selectedCategory = ViewBag.SelectedCategory as int?;
}

<div class="container my-4">

    <!-- Slider/banner nổi bật -->
    <div id="bookCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/images/LapTrinhC.jpg" class="d-block w-100" alt="Banner 1" style="height:auto; max-height:400px; object-fit:cover;">
            </div>
            <div class="carousel-item">
                <img src="~/images/nhanhandcham.jpg" class="d-block w-100" alt="Banner 2" style="height:auto; max-height:400px; object-fit:cover;">
            </div>
            <div class="carousel-item">
                <img src="~/images/cotinhvn.jpg" class="d-block w-100" alt="Banner 3" style="height:auto; max-height:400px; object-fit:cover;">
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#bookCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#bookCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

    <h2 class="mb-4 text-primary fw-bold text-center">📚 Danh sách sách</h2>

    <!-- Form lọc & sắp xếp -->
    <form asp-action="Index" method="get" class="mb-3 d-flex gap-2 flex-wrap justify-content-center">
        <input type="text" name="searchString"
               value="@Context.Request.Query["searchString"]"
               placeholder="Tìm kiếm sách..." class="form-control w-25" />

        <select name="categoryId" class="form-select w-25">
            <option value="">-- Tất cả thể loại --</option>
            @if (categories != null)
            {
                foreach (var cat in categories)
                {
                    <option value="@cat.MaLoai" selected="@(selectedCategory == cat.MaLoai)">
                        @cat.TenLoai
                    </option>
                }
            }
        </select>

        <select name="sortOrder" class="form-select w-25">
            <option value="">Mặc định</option>
            <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc")">Giá tăng dần</option>
            <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc")">Giá giảm dần</option>
        </select>

        <button type="submit" class="btn btn-primary">Lọc</button>
    </form>

    <!-- Card sách -->
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm hover-card">
                    <img src="~/images/@item.HinhAnh" class="card-img-top" alt="@item.TenSach" style="height:250px; object-fit:cover;" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.TenSach</h5>
                        <p class="card-text text-muted">Tác giả: @item.TacGia</p>
                        <p class="fw-bold text-danger">@item.GiaBan.ToString("n0") ₫</p>

                        @if (item.SoLuong > 0)
                        {
                            <span class="badge bg-success mb-2">Còn hàng</span>
                        }
                        else
                        {
                            <span class="badge bg-danger mb-2">Hết hàng</span>
                        }

                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@item.MaSach" class="btn btn-info btn-sm w-100 mb-2">
                                <i class="bi bi-info-circle"></i> Chi tiết
                            </a>
                            <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.MaSach"
                               class="btn btn-success btn-sm w-100 @(item.SoLuong == 0 ? "disabled" : "")">
                                <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage-1)">«</a>
            </li>
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                       asp-route-searchString="@Context.Request.Query["searchString"]"
                       asp-route-categoryId="@selectedCategory"
                       asp-route-sortOrder="@ViewBag.CurrentSort">
                        @i
                    </a>
                </li>
            }
            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage+1)">»</a>
            </li>
        </ul>
    </nav>
</div>

<style>
    .hover-card {
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    /* Carousel ảnh nét hơn */
    #bookCarousel img {
        width: 100%;
        height: auto;
        max-height: 400px;
        object-fit: cover;
        image-rendering: auto;
    }
</style>

@model IEnumerable<QLBanSachWeb.Models.Sach>

@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as List<QLBanSachWeb.Models.LoaiSach>;
    int? selectedCategory = ViewBag.SelectedCategory as int?;
}

<div class="container my-4">


    <!-- Slider/banner nổi bật -->
    <div id="bookCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
        <div class="carousel-inner">

            <!-- Banner 1 -->
            <div class="carousel-item active">
                <img src="https://tse1.mm.bing.net/th/id/OIP.HPs0lgyjHws8mTbpAF9_kAHaEo?pid=Api&P=0&h=220"
                     class="d-block w-100 card-img-top" alt="Banner 1"
                     style="height: 350px; object-fit: cover;">
            </div>

            <!-- Banner 2 -->
            <div class="carousel-item">
                <img src="https://tse2.mm.bing.net/th/id/OIP.vlX6Pec8eEGmwuayITNPxwHaFj?pid=Api&P=0&h=220"
                     class="d-block w-100 card-img-top" alt="Banner 2"
                     style="height: 350px; object-fit: cover;">
            </div>

            <!-- Banner 3 -->
            <div class="carousel-item">
                <img src="https://images-na.ssl-images-amazon.com/images/I/51b5YG6Y1rL._SX329_BO1,204,203,200_.jpg"
                     class="d-block w-100 card-img-top" alt="Banner 3"
                     style="height: 350px; object-fit: cover;">
            </div>

        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#bookCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next" type="button" data-bs-target="#bookCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>




    <h2 class="mb-4 text-primary fw-bold text-center">📚 Danh sách sách</h2>

    <!-- Form lọc & sắp xếp -->
    <form asp-action="Index" method="get" class="mb-4">
        <div class="filter-bar shadow-sm p-3 rounded bg-white d-flex flex-wrap align-items-center gap-3">

            <!-- Ô tìm kiếm -->
            <div class="flex-grow-1">
                <div class="input-group rounded-pill shadow-sm">
                    <span class="input-group-text bg-white border-0 rounded-start-pill">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" name="searchString"
                           value="@Context.Request.Query["searchString"]"
                           placeholder="🔍 Tìm sách theo tên, tác giả..."
                           class="form-control border-0 rounded-end-pill" />
                </div>
            </div>

            <!-- Thể loại -->
            <div>
                <select name="categoryId" class="form-select rounded-pill shadow-sm">
                    <option value="">📂 Tất cả thể loại</option>
                    @if (categories != null)
                    {
                        foreach (var cat in categories)
                        {
                            <option value="@cat.MaLoai" selected="@(selectedCategory == cat.MaLoai)">
                                @cat.TenLoai
                            </option>
                        }
                    }
                </select>
            </div>

            <!-- Sắp xếp -->
            <div>
                <select name="sortOrder" class="form-select rounded-pill shadow-sm">
                    <option value="">🔀 Mặc định</option>
                    <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc")">💲 Giá tăng dần</option>
                    <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc")">💲 Giá giảm dần</option>
                </select>
            </div>

            <!-- Nút lọc -->
            <div>
                <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                    <i class="bi bi-funnel"></i> Lọc
                </button>
            </div>
        </div>
    </form>

    <!-- Card sách -->
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="book-card shadow-sm border-0 rounded h-100 d-flex flex-column">

                    <!-- Ảnh sách -->
                    <div class="book-img-wrapper position-relative">
                        <img src="~/images/@item.HinhAnh"
                             alt="@item.TenSach"
                             class="book-img img-fluid" />

                        <!-- Badge tình trạng -->
                        @if (item.SoLuong > 0)
                        {
                            <span class="badge bg-success position-absolute top-0 start-0 m-2">✔ Còn hàng</span>
                        }
                        else
                        {
                            <span class="badge bg-danger position-absolute top-0 start-0 m-2">❌ Hết hàng</span>
                        }

                        <!-- Overlay khi hover -->
                        <div class="overlay d-flex flex-column justify-content-center align-items-center">
                            <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.MaSach"
                               class="btn btn-success btn-sm w-75 mb-2 @(item.SoLuong == 0 ? "disabled" : "")">
                                <i class="bi bi-cart-plus"></i> Thêm giỏ
                            </a>
                            <a asp-action="Details" asp-route-id="@item.MaSach"
                               class="btn btn-outline-light btn-sm w-75">
                                <i class="bi bi-info-circle"></i> Chi tiết
                            </a>
                        </div>
                    </div>

                    <!-- Thông tin sách -->
                    <div class="p-3 text-center mt-auto">
                        <h6 class="fw-bold text-truncate">@item.TenSach</h6>
                        <p class="text-muted small mb-1">✍ @item.TacGia</p>
                        <p class="fw-bold text-danger">@item.GiaBan.ToString("n0") ₫</p>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage-1)">«</a>
            </li>
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                       asp-route-searchString="@Context.Request.Query["searchString"]"
                       asp-route-categoryId="@selectedCategory"
                       asp-route-sortOrder="@ViewBag.CurrentSort">
                        @i
                    </a>
                </li>
            }
            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage+1)">»</a>
            </li>
        </ul>
    </nav>
</div>

<style>


/* Thanh filter bar */
.filter-bar {
    background: #f8f9fa;
    border: 1px solid #e1e1e1;
}

    .filter-bar select,
    .filter-bar input {
        min-width: 180px;
    }

    .filter-bar .form-select:focus,
    .filter-bar .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 6px rgba(13,110,253,0.3);
    }

/* Card sách hiện đại */
.book-card {
    border-radius: 14px;
    overflow: hidden;
    background: #fff;
    transition: transform 0.3s, box-shadow 0.3s;
    min-height: 440px; /* đồng đều */
}

    .book-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }

/* Ảnh sách */
.book-img-wrapper {
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
}

.book-img {
    width: 100%;
    height: 340px;
    object-fit: cover;
    transition: transform 0.4s ease;
    border-bottom: 1px solid #eee;
}

.book-card:hover .book-img {
    transform: scale(1.08);
}

/* Overlay khi hover */
.overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
    opacity: 0;
    transition: opacity 0.3s;
}

.book-card:hover .overlay {
    opacity: 1;
}
</style>

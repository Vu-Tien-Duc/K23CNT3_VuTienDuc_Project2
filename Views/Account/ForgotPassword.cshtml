@{
    ViewData["Title"] = "Quên mật khẩu";
}

<h2 class="mb-3">Quên mật khẩu</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form asp-action="ForgotPassword" method="post">
    <div class="mb-3">
        <label for="email" class="form-label">Nhập email đã đăng ký</label>
        <input type="email" name="email" class="form-control" required />
    </div>
    <button type="submit" class="btn btn-primary">Gửi mật khẩu mới</button>
    <a asp-action="Login" class="btn btn-secondary">Quay lại đăng nhập</a>
</form>

@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg">
                <div class="card-body">
                    <h3 class="text-center text-primary mb-4">Quên mật khẩu</h3>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email của bạn</label>
                            <input type="email" name="email" class="form-control" placeholder="Nhập email đã đăng ký" required />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Lấy mật khẩu mới</button>
                        </div>
                    </form>

                    <div class="text-center mt-3">
                        <a asp-action="Login" class="btn btn-link">Quay lại đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@model IEnumerable<QLBanSachWeb.Models.GioHang>

<h2 class="mb-4">📦 Danh sách Giỏ Hàng</h2>

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Mã GH</th>
            <th>Khách hàng</th>
            <th>Ngày tạo</th>
            <th>Số lượng SP</th>
            <th>Tổng tiền</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var gh in Model)
        {
            <tr>
                <td>@gh.MaGH</td>
                <td>@gh.MaKHNavigation?.HoTen</td>
                <td>@gh.NgayTao?.ToString("dd/MM/yyyy")</td>
                <td>@gh.CT_GioHangs.Sum(c => c.SoLuong)</td>
                <td>@gh.CT_GioHangs.Sum(c => c.SoLuong * c.MaSachNavigation.GiaBan).ToString("N0") đ</td>
                <td>
                    <!-- Details -->
                    <a asp-action="Details" asp-route-id="@gh.MaGH" class="btn btn-info btn-sm me-1">
                        <i class="bi bi-eye"></i> Xem
                    </a>

                    <!-- Delete trigger -->
                    <button type="button" class="btn btn-sm btn-danger p-1" data-bs-toggle="modal" data-bs-target="#deleteModal-@gh.MaGH">
                        <i class="bi bi-trash"></i> Xóa
                    </button>

                    <!-- Modal Delete -->
                    <div class="modal fade" id="deleteModal-@gh.MaGH" tabindex="-1" aria-labelledby="deleteModalLabel-@gh.MaGH" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header bg-danger text-white">
                                    <h5 class="modal-title" id="deleteModalLabel-@gh.MaGH">Xác nhận xóa</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    Bạn có chắc chắn muốn xóa giỏ hàng của "<strong>@gh.MaKHNavigation?.HoTen</strong>" (Mã GH: @gh.MaGH) không?
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                    <form asp-action="Delete" asp-route-id="@gh.MaGH" method="post" asp-antiforgery="true">
                                        <button type="submit" class="btn btn-danger">Xóa</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- End Modal -->
                </td>
            </tr>
        }
    </tbody>
</table>

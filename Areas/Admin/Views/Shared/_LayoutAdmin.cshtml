@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Trị</title>
   
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin-darkmode.css" />
    <link rel="stylesheet" href="~/css/layoutAdmin.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.0/font/bootstrap-icons.css">

    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="d-flex" style="min-height: 100vh; flex-direction: row;">

        <!-- Sidebar -->
        <div class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <img src="@Context.Session.GetString("HinhAnh")" alt="Admin Avatar" />
                <h5>@Context.Session.GetString("TenAdmin")</h5>
                <small>Quản trị viên</small>
            </div>

            <div class="nav-links">
                <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">🏠 Trang chủ</a>
                <a asp-area="Admin" asp-controller="Saches" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Saches" ? "active" : "")">📚 Quản lý Sách</a>
                <a asp-area="Admin" asp-controller="LoaiSaches" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "LoaiSaches" ? "active" : "")">🗂️ Quản lý Loại Sách</a>
                <a asp-area="Admin" asp-controller="KhachHangs" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "KhachHangs" ? "active" : "")">👤 Khách Hàng</a>
                <a asp-area="Admin" asp-controller="GioHang" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "GioHang" ? "active" : "")">🛒 Giỏ Hàng</a>
                <a asp-area="Admin" asp-controller="DonHang" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "DonHang" ? "active" : "")">🧾 Đơn Hàng</a>
            </div>

            <div class="sidebar-bottom">
                <div class="mode-toggle" onclick="toggleMode()">
                    <i class="bi bi-moon"></i>
                    <span>Chế độ tối</span>
                </div>
                <a asp-area="" asp-controller="Home" asp-action="Index" class="logout-btn text-danger mt-3">
                    🚪 Đăng xuất
                </a>
            </div>
        </div>

        <!-- Hamburger Button -->
        <button class="btn btn-dark d-md-none m-2" id="hamburgerBtn">
            <i class="bi bi-list"></i>
        </button>

        <!-- Content -->
        <div class="content d-flex flex-column flex-grow-1">
            <div class="container-fluid flex-grow-1">
                <div class="card p-4">
                    @RenderBody()
                </div>
            </div>

            <!-- Footer -->
            <footer class="mt-auto">
                <small>© 2025 - Hệ thống quản trị bán sách</small>
            </footer>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Dark mode mặc định theo localStorage
            if (localStorage.getItem("darkMode") === "true") {
                document.body.classList.add("dark");
            }

            // Toggle dark mode
            window.toggleMode = function () {
                document.body.classList.toggle("dark");
                localStorage.setItem("darkMode", document.body.classList.contains("dark"));
                document.dispatchEvent(new Event("darkModeChanged"));
            };

            // Hàm áp dụng dark mode cho toàn trang
            function applyDarkMode() {
                const dark = document.body.classList.contains("dark");

                // Card
                document.querySelectorAll(".card").forEach(c => {
                    c.style.transition = "background-color 0.5s, color 0.5s";
                    c.style.backgroundColor = dark ? "#333" : "#fff";
                    c.style.color = dark ? "#f1f1f1" : "#000";
                });

                // Table
                document.querySelectorAll("table").forEach(t => {
                    t.style.transition = "background-color 0.5s, color 0.5s";
                    t.style.backgroundColor = dark ? "#2a2a2a" : "#fff";
                    t.style.color = dark ? "#f1f1f1" : "#000";
                });

                // Form control
                document.querySelectorAll(".form-control").forEach(fc => {
                    fc.style.transition = "background-color 0.5s, color 0.5s";
                    fc.style.backgroundColor = dark ? "#333" : "#fff";
                    fc.style.color = dark ? "#f1f1f1" : "#000";
                });
            }

            // Lắng nghe sự kiện đổi mode
            document.addEventListener("darkModeChanged", applyDarkMode);

            // Load lần đầu
            applyDarkMode();
        });
    </script>




    @RenderSection("Scripts", required: false)
</body>
</html>

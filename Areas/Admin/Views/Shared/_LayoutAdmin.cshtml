<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Trị</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <a class="navbar-brand" asp-area="Admin" asp-controller="Home" asp-action="Index">Trang Quản Trị</a>
        <div class="navbar-nav">
            <a class="nav-item nav-link" asp-area="Admin" asp-controller="Saches" asp-action="Index">📚 Quản lý Sách</a>
            <a class="nav-item nav-link" asp-area="Admin" asp-controller="KhachHangs" asp-action="Index">👤 Khách Hàng</a>
            <a class="nav-item nav-link" asp-area="Admin" asp-controller="HoaDon" asp-action="Index">🧾 Hóa Đơn</a>
           
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="bg-dark text-white text-center p-3 mt-4">
        © 2025 - Hệ thống quản trị bán sách
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    @RenderSection("Scripts", required: false)
</body>

</html>

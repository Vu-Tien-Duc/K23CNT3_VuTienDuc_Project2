@model QLBanSachWeb.Models.LoaiSach

@{
    ViewData["Title"] = "Chi Tiết Loại Sách";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="bi bi-tags"></i> Chi Tiết Loại Sách</h4>
                <a asp-action="Index" class="btn btn-secondary btn-sm">
                    <i class="bi bi-arrow-left-circle"></i> Quay Lại
                </a>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Mã Loại:</dt>
                    <dd class="col-sm-8">@Model.MaLoai</dd>

                    <dt class="col-sm-4">Tên Loại:</dt>
                    <dd class="col-sm-8">@Model.TenLoai</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

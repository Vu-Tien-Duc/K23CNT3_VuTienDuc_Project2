@model QLBanSachWeb.Models.LoaiSach

@{
    ViewData["Title"] = "Chi tiết loại sách";
}

<h1>Chi tiết loại sách</h1>
<hr />
<dl class="row">
    <dt class="col-sm-2">Mã loại</dt>
    <dd class="col-sm-10">@Model.MaLoai</dd>

    <dt class="col-sm-2">Tên loại</dt>
    <dd class="col-sm-10">@Model.TenLoai</dd>
</dl>
<a asp-action="Index" class="btn btn-secondary">Quay lại</a>

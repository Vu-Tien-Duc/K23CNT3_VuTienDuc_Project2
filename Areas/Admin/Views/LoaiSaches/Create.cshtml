@model QLBanSachWeb.Models.LoaiSach

@{
    ViewData["Title"] = "Thêm loại sách";
}

<h1 class="mb-4">Thêm loại sách</h1>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="TenLoai" class="form-label">Tên loại</label>
                        <input asp-for="TenLoai" class="form-control" placeholder="Nhập tên loại sách..." />
                        <span asp-validation-for="TenLoai" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <input type="submit" value="Lưu" class="btn btn-primary" />
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}

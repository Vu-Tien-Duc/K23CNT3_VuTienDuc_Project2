@model IEnumerable<QLBanSachWeb.Models.DonHang>
@{
    ViewData["Title"] = "Danh sách Đơn Hàng";
}

<h2 class="mb-4">📃 Danh sách Đơn Hàng</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Create" class="btn btn-success btn-lg shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Thêm đơn hàng mới
    </a>
</div>


<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Mã DH</th>
            <th>Khách hàng</th>
            <th>Ngày đặt</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var dh in Model)
        {
            string badgeClass = dh.TrangThai switch
            {
                "Chờ xử lý" => "badge bg-warning text-dark",
                "Đang giao" => "badge bg-info text-dark",
                "Đã giao" => "badge bg-success",
                "Đã hủy" => "badge bg-danger",
                _ => "badge bg-secondary"
            };

            <tr>
                <td>@dh.MaDH</td>
                <td>@dh.MaKHNavigation?.HoTen</td>
                <td>@dh.NgayDat?.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@dh.TongTien?.ToString("N0") đ</td>
                <td><span class="@badgeClass">@dh.TrangThai</span></td>
                <td>
                    <!-- Details -->
                    <a asp-action="Details" asp-route-id="@dh.MaDH" class="btn btn-info btn-sm me-1">
                        <i class="bi bi-eye"></i> Xem
                    </a>

                    <!-- Edit -->
                    <a asp-action="Edit" asp-route-id="@dh.MaDH" class="btn btn-warning btn-sm me-1">
                        <i class="bi bi-pencil-square"></i> Sửa
                    </a>

                    <!-- Delete trigger -->
                    <button type="button" class="btn btn-danger btn-sm p-1" data-bs-toggle="modal" data-bs-target="#deleteModal-@dh.MaDH">
                        <i class="bi bi-trash"></i> Xóa
                    </button>

                    <!-- Modal Delete -->
                    <div class="modal fade" id="deleteModal-@dh.MaDH" tabindex="-1" aria-labelledby="deleteModalLabel-@dh.MaDH" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header bg-danger text-white">
                                    <h5 class="modal-title" id="deleteModalLabel-@dh.MaDH">Xác nhận xóa</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    Bạn có chắc chắn muốn xóa đơn hàng của "<strong>@dh.MaKHNavigation?.HoTen</strong>" (Mã DH: @dh.MaDH) không?
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                    <form asp-action="Delete" asp-route-id="@dh.MaDH" method="post" asp-antiforgery="true">
                                        <button type="submit" class="btn btn-danger">Xóa</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- End Modal -->
                </td>
            </tr>
        }
    </tbody>
</table>

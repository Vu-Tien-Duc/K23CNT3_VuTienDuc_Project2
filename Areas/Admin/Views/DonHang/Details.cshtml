@model QLBanSachWeb.Models.DonHang

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<h2 class="mb-4">📄 Chi tiết Đơn Hàng</h2>

<div class="shadow-sm p-4 bg-white rounded">
    <div class="row mb-3">
        <dl class="col-md-6">
            <dt>Mã Đơn Hàng:</dt>
            <dd>@Model.MaDH</dd>

            <dt>Khách hàng:</dt>
            <dd>@Model.MaKHNavigation?.HoTen</dd>

            <dt>Ngày đặt:</dt>
            <dd>@Model.NgayDat?.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt>Tổng tiền:</dt>
            <dd>@Model.TongTien?.ToString("N0") đ</dd>

            <dt>Trạng thái:</dt>
            <dd>
                @{
                    var badgeClass = Model.TrangThai switch
                    {
                        "Chờ xử lý" => "badge bg-warning text-dark",
                        "Đang giao" => "badge bg-info text-dark",
                        "Đã giao" => "badge bg-success",
                        "Đã hủy" => "badge bg-danger",
                        _ => "badge bg-secondary"
                    };
                }
                <span class="@badgeClass">@Model.TrangThai</span>
            </dd>
        </dl>
    </div>

    <h5>📦 Chi tiết sản phẩm</h5>
    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Sản phẩm</th>
                <th>Đơn giá</th>
                <th>Số lượng</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.CT_DonHangs)
            {
                <tr>
                    <td>@item.MaSachNavigation?.TenSach</td>
                    <td>@item.MaSachNavigation?.GiaBan.ToString("N0") đ</td>
                    <td>@item.SoLuong</td>
                    <td>@((item.SoLuong * item.MaSachNavigation.GiaBan).ToString("N0")) đ</td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="Index" class="btn btn-secondary mt-3">
        <i class="bi bi-arrow-left-circle"></i> Quay lại
    </a>
</div>

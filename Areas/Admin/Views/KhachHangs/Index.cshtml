@model IEnumerable<QLBanSachWeb.Models.KhachHang>

@{
    ViewData["Title"] = "Danh sách khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Danh sách khách hàng</h2>
    <a asp-action="Create" class="btn btn-success shadow-sm">
        <i class="bi bi-person-plus me-1"></i> Thêm mới
    </a>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark text-center">
            <tr>
                <th>Mã KH</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>SĐT</th>
                <th>Địa chỉ</th>
                <th style="width:160px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaKH</td>
                    <td>@item.HoTen</td>
                    <td>@item.Email</td>
                    <td>@item.SDT</td>
                    <td>@item.DiaChi</td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-1">
                            <!-- Edit -->
                            <a asp-action="Edit" asp-route-id="@item.MaKH" class="btn btn-sm btn-warning p-1">
                                <i class="bi bi-pencil-square"></i>
                            </a>

                            <!-- Details -->
                            <a asp-action="Details" asp-route-id="@item.MaKH" class="btn btn-sm btn-info p-1">
                                <i class="bi bi-eye"></i>
                            </a>

                            <!-- Delete trigger -->
                            <button type="button" class="btn btn-sm btn-danger p-1" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.MaKH">
                                <i class="bi bi-trash"></i>
                            </button>

                            <!-- Modal Delete -->
                            <div class="modal fade" id="deleteModal-@item.MaKH" tabindex="-1" aria-labelledby="deleteModalLabel-@item.MaKH" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-header bg-danger text-white">
                                            <h5 class="modal-title" id="deleteModalLabel-@item.MaKH">Xác nhận xóa</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            Bạn có chắc chắn muốn xóa khách hàng "<strong>@item.HoTen</strong>" không?
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                            <form asp-action="Delete" asp-route-id="@item.MaKH" method="post" asp-antiforgery="true">
                                                <button type="submit" class="btn btn-danger">Xóa</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

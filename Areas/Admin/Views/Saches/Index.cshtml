@model X.PagedList.IPagedList<QLBanSachWeb.Models.Sach>
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Quản lý Sách";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">

    <!-- Header + Thêm mới -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold">📚 Quản lý sách</h1>
        <a asp-area="Admin" asp-controller="Saches" asp-action="Create" class="btn btn-success btn-lg shadow-sm">
            ➕ Thêm mới
        </a>
    </div>

    <!-- Search box -->
    <form method="get" class="mb-4">
        <div class="input-group shadow-sm rounded overflow-hidden" style="max-width:500px; transition: box-shadow 0.3s;">
            <input type="text" name="searchString"
                   class="form-control border-0 px-3 py-2"
                   placeholder="🔎 Tìm kiếm sách..."
                   value="@ViewBag.SearchString"
                   style="border-radius:0; outline:none;">
            <button type="submit" class="btn btn-primary px-4">Tìm</button>
        </div>
    </form>

    <!-- Table -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table align-middle mb-0 table-hover">
            <thead class="table-dark text-center">
                <tr>
                    <th>Hình ảnh</th>
                    <th>Tên sách</th>
                    <th>Tác giả</th>
                    <th>Loại sách</th>
                    <th>NXB</th>
                    <th>Năm XB</th>
                    <th>Giá bán</th>
                    <th>Số lượng</th>
                    <th>Mô tả</th>
                    <th style="min-width:180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="shadow-sm rounded mb-1 align-middle">
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(item.HinhAnh))
                            {
                                <img src="~/images/@item.HinhAnh" class="img-thumbnail" style="width:80px; height:100px; object-fit:cover;" />
                            }
                            else
                            {
                                <span class="text-muted">Không có</span>
                            }
                        </td>
                        <td>@item.TenSach</td>
                        <td>@item.TacGia</td>
                        <td>@item.MaLoaiNavigation?.TenLoai</td>
                        <td>@item.NXB</td>
                        <td>@item.NamXB</td>
                        <td>@item.GiaBan.ToString("C0")</td>
                        <td>@item.SoLuong</td>
                        <td class="text-truncate" style="max-width:150px;">@item.MoTa</td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.MaSach" class="btn btn-sm btn-warning">✏️ Edit</a>
                                <a asp-action="Details" asp-route-id="@item.MaSach" class="btn btn-sm btn-info">ℹ️ Details</a>
                                <form asp-action="Delete" asp-route-id="@item.MaSach" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Bạn có chắc chắn muốn xóa sách này?');">
                                        🗑️ Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-center mt-4">
        @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchString = ViewBag.SearchString }), new PagedListRenderOptions
   {
       LiElementClasses = new[] { "page-item" },
       PageClasses = new[] { "page-link" },
       UlElementClasses = new[] { "pagination" }
   })
    </div>
</div>

@section Styles {
    <style>
        /* Hover hiệu ứng + shadow */
        .table tbody tr {
            transition: all 0.3s;
            border-radius: 0.25rem;
        }

            .table tbody tr:hover {
                background: rgba(13,110,253,0.1);
                transform: translateY(-2px);
            }

        .table-responsive {
            transition: background 0.3s, color 0.3s;
        }

        /* Text truncate */
        .text-truncate {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Buttons hover */
        .btn:hover {
            filter: brightness(0.9);
        }
    </style>
}

@section Scripts {
    <script>
        // Optionally: Dark mode support
        document.addEventListener("darkModeChanged", () => {
            document.querySelectorAll(".table-responsive").forEach(tbl => {
                if (document.body.classList.contains('dark')) {
                    tbl.querySelectorAll("th").forEach(th => th.style.backgroundColor = '#111');
                    tbl.querySelectorAll("th").forEach(th => th.style.color = '#fff');
                    tbl.querySelectorAll("td").forEach(td => td.style.color = '#f1f1f1');
                } else {
                    tbl.querySelectorAll("th").forEach(th => th.style.backgroundColor = '');
                    tbl.querySelectorAll("th").forEach(th => th.style.color = '');
                    tbl.querySelectorAll("td").forEach(td => td.style.color = '');
                }
            });
        });
    </script>
}

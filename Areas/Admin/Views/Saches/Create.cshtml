@model QLBanSachWeb.Models.Sach

@{
    ViewData["Title"] = "Thêm Sách";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2>Thêm Sách</h2>

<form asp-action="Create" enctype="multipart/form-data">
    <div class="form-group">
        <label asp-for="TenSach"></label>
        <input asp-for="TenSach" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="TacGia"></label>
        <input asp-for="TacGia" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="MaLoai"></label>
        <select asp-for="MaLoai" asp-items="ViewBag.MaLoai" class="form-control"></select>
    </div>

    <div class="form-group">
        <label asp-for="NXB"></label>
        <input asp-for="NXB" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="NamXB"></label>
        <input asp-for="NamXB" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="GiaBan"></label>
        <input asp-for="GiaBan" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="SoLuong"></label>
        <input asp-for="SoLuong" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="MoTa"></label>
        <textarea asp-for="MoTa" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label asp-for="HinhAnhFile">Chọn ảnh</label>
        <input asp-for="HinhAnhFile" type="file" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>

@model QLBanSachWeb.Models.Sach

@{
    ViewData["Title"] = "Thêm sách mới";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="TenSach" class="form-label">Tên Sách</label>
            <input asp-for="TenSach" class="form-control" placeholder="Nhập tên sách" />
            <span asp-validation-for="TenSach" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="TacGia" class="form-label">Tác Giả</label>
            <input asp-for="TacGia" class="form-control" placeholder="Nhập tác giả" />
            <span asp-validation-for="TacGia" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="MaLoai" class="form-label">Loại Sách</label>
            <select asp-for="MaLoai" asp-items="ViewBag.MaLoai" class="form-select"></select>
            <span asp-validation-for="MaLoai" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="NXB" class="form-label">Nhà Xuất Bản</label>
            <input asp-for="NXB" class="form-control" placeholder="Nhập nhà xuất bản" />
            <span asp-validation-for="NXB" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="NamXB" class="form-label">Năm Xuất Bản</label>
            <input asp-for="NamXB" type="number" class="form-control" placeholder="2025" />
            <span asp-validation-for="NamXB" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="GiaBan" class="form-label">Giá Bán (VNĐ)</label>
            <input asp-for="GiaBan" type="number" class="form-control" placeholder="100000" />
            <span asp-validation-for="GiaBan" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="SoLuong" class="form-label">Số Lượng</label>
            <input asp-for="SoLuong" type="number" class="form-control" placeholder="10" />
            <span asp-validation-for="SoLuong" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="MoTa" class="form-label">Mô Tả</label>
            <textarea asp-for="MoTa" class="form-control" rows="3" placeholder="Nhập mô tả sách"></textarea>
            <span asp-validation-for="MoTa" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="HinhAnhFile" class="form-label">Chọn Ảnh Sách</label>
            <input asp-for="HinhAnhFile" type="file" class="form-control" />
            @if (!string.IsNullOrEmpty(Model?.HinhAnh))
            {
                <img src="~/images/@Model.HinhAnh" class="img-thumbnail mt-2" style="max-width:150px;" />
            }
            <span asp-validation-for="HinhAnhFile" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-4 d-flex justify-content-end gap-2">
        <button type="submit" class="btn btn-success btn-lg">Thêm Mới</button>
        <a asp-action="Index" class="btn btn-secondary btn-lg">Hủy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
